# ===================================
# LLM Configuration (脚本生成)
# ===================================

# DeepSeek API (官方)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# GLM (智谱AI) - 支持多模态
GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-4.6v

# LLM Provider Selection
# 可选值: "deepseek" | "glm" | "ark" (火山方舟托管的模型)
LLM_PROVIDER=ark

# 火山方舟托管的 LLM 模型 (仅当 LLM_PROVIDER=ark 时使用)
# 可选: doubao-1-5-pro-32k, doubao-1-8-pro, deepseek-v3-2-251201
ARK_LLM_MODEL=deepseek-v3-2-251201

# ===================================
# Volcengine Ark Configuration (图像/视频生成)
# ===================================

# 获取方式: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 视频生成模型
ARK_VIDEO_MODEL=doubao-seedance-1-5-pro
# 图像生成模型
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128
# 多模态模型（用于参考图分析）
ARK_VISION_MODEL=doubao-seed-1-6-251015

# ===================================
# Image Generation Parameters (图像生成参数)
# ===================================

# 图像宽高比: "1:1", "16:9", "9:16", "4:3", "3:4"
IMAGE_ASPECT_RATIO=16:9

# 可选风格描述，如 "赛璐璐渲染", "工作室灯光", "电影级光影"
IMAGE_STYLE=

# 参考图风格权重 (0.0-1.0)，越高越接近参考图风格
IMAGE_STYLE_WEIGHT=0.7

# ===================================
# Character Consistency Parameters (角色一致性)
# ===================================

# 固定随机种子，确保所有分镜风格一致（留空则自动生成）
IMAGE_SEED=

# 角色外貌描述前缀，会自动添加到每个分镜的视觉描述开头
# 示例: "一只金色柯基犬，戴着红色围巾，大眼睛，圆润的脸"
CHARACTER_DESCRIPTION=

# ===================================
# Workflow Configuration (工作流配置)
# ===================================

# 并发任务数量
WORKFLOW_CONCURRENCY=2

# 输出目录
OUTPUT_DIR=outputs
